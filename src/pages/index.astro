---
import Layout from '../layouts/Layout.astro';
---

<Layout title="zpot">
  <main class="page">
    <div class="bg-gradient"></div>
    <div class="bg-grid"></div>

    <div class="particles">
      <span class="particle"></span>
      <span class="particle"></span>
      <span class="particle"></span>
      <span class="particle"></span>
      <span class="particle"></span>
      <span class="particle"></span>
      <span class="particle"></span>
    </div>

    <section class="hero">
      <div class="container">
        <div class="logo-container">
          <img src="/logo.png" alt="ZPOT Logo" class="logo" />
        </div>
        <div class="type-area" aria-live="polite">
          <div class="type-line">
              <span class="prompt">$</span>
              <span class="typewriter" style="--chars:14;">coming soon...</span>
            </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .page {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    padding: 3.5rem 1.5rem 4rem;
    display: grid;
    place-items: center;
  }

  .bg-gradient,
  .bg-grid {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .bg-gradient {
    background: radial-gradient(circle at 18% 18%, rgba(0, 167, 120, 0.14), transparent 30%),
                radial-gradient(circle at 78% 12%, rgba(0, 82, 71, 0.12), transparent 26%),
                radial-gradient(circle at 65% 82%, rgba(32, 38, 50, 0.08), transparent 30%);
    filter: blur(18px);
    opacity: 0.65;
    animation: drift 18s ease-in-out infinite;
  }

  .bg-grid {
    background-image:
      linear-gradient(rgba(32, 38, 50, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(32, 38, 50, 0.05) 1px, transparent 1px);
    background-size: 52px 52px;
    opacity: 0.35;
  }

  .particles {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .particle {
    position: absolute;
    width: 6px;
    height: 6px;
    background: #00a778;
    border-radius: 50%;
    opacity: 0.6;
    animation: float 20s infinite;
    filter: drop-shadow(0 0 6px rgba(0, 167, 120, 0.4));
  }

  .particle:nth-child(1) { left: 10%; animation-delay: 0s; animation-duration: 17s; }
  .particle:nth-child(2) { left: 25%; animation-delay: 1.5s; animation-duration: 21s; }
  .particle:nth-child(3) { left: 40%; animation-delay: 3s; animation-duration: 19s; }
  .particle:nth-child(4) { left: 55%; animation-delay: 0.5s; animation-duration: 23s; }
  .particle:nth-child(5) { left: 70%; animation-delay: 2.5s; animation-duration: 20s; }
  .particle:nth-child(6) { left: 82%; animation-delay: 1s; animation-duration: 18s; }
  .particle:nth-child(7) { left: 92%; animation-delay: 3.5s; animation-duration: 22s; }

  .hero {
    position: relative;
    z-index: 1;
    width: 100%;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .logo-container {
    animation: float 6s ease-in-out infinite;
  }

  .logo {
    max-width: 260px;
    height: auto;
    display: block;
  }

  .subhead {
    font-size: 1.1rem;
    color: var(--color-midnight);
    font-weight: 700;
    letter-spacing: 0.01em;
  }

  .type-area {
    margin-top: 0.5rem;
    display: flex;
    justify-content: center;
    width: min(760px, 100%);
  }

  .type-line {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: #202632;
    border: 2px solid #00a778;
    border-radius: 6px;
    padding: 0.75rem 1rem;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.35), inset 0 0 10px rgba(0, 167, 120, 0.2);
    font-family: 'VT323', 'IBM Plex Mono', 'SFMono-Regular', 'Menlo', monospace;
    color: #dce7e2;
    min-width: 320px;
  }

  .prompt {
    color: #00a778;
    font-weight: 800;
  }

  .typewriter {
    display: block;
    width: auto;
    max-width: none;
    white-space: nowrap;
    overflow: hidden;
    border-right: 2px solid #00a778;
    padding-right: 2px;
    color: #dce7e2;
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    50% { border-color: transparent; }
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-12px); }
  }

  @keyframes drift {
    0%, 100% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(0, -18px, 0); }
  }


  @media (max-width: 768px) {
    .page {
      padding: 2.5rem 1.25rem 3rem;
    }

    .logo-container {
      padding: 1rem 1.1rem;
    }
  }
</style>